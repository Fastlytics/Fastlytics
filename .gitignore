# Backend API Directory (Specific Rules)
# Ignore the entire directory by default
/backend-api/
# But DO NOT ignore a .gitignore file within it, allowing specific un-ignores
!/backend-api/.gitignore
# Ignore environment files within the backend directory
/backend-api/.env*
# Ignore Python cache/compiled files
/backend-api/cache/
/backend-api/__pycache__/
/backend-api/*.pyc
/.kilocode/

