# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API Configuration
# Points to Cloudflare Worker proxy (https://api.fastlytics.app)
# The worker injects API key server-side
VITE_API_BASE_URL=https://api.fastlytics.app

# Optional for local development when calling backend directly (e.g. http://localhost:8000)
# Must match FASTLYTICS_API_KEY in backend-api/.env
VITE_FASTLYTICS_API_KEY=



# Analytics (Optional)
# Set this to "true" to enable telemetry (for production deployments).
# If false or omitted, all tracking is disabled.
VITE_ENABLE_TELEMETRY=false
VITE_UMAMI_WEBSITE_ID=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
